export NVM_DIR="$HOME/.nvm"
NODE_VER=$(cat .nvmrc 2>/dev/null)
case "$NODE_VER" in v*) ;; *) NODE_VER="v$NODE_VER" ;; esac
if [ -d "$NVM_DIR/versions/node/$NODE_VER/bin" ]; then
  export PATH="$NVM_DIR/versions/node/$NODE_VER/bin:$PATH"
fi

set -e

pnpm format:check:changed
pnpm lint
pnpm prisma-query:changed
pnpm transaction-guard:changed
pnpm mcdc:changed --fail-on-missing
