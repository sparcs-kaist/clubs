// Prisma Schema - migrated from Drizzle ORM
// All DateTime fields stored as KST in MySQL.
// Timezone conversion handled by PrismaService middleware.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User & Auth
// ============================================================================

model User {
  id          Int       @id @default(autoincrement())
  sid         String?   @unique @db.VarChar(30)
  name        String    @db.VarChar(255)
  email       String?   @db.VarChar(255)
  phoneNumber String?   @map("phone_number") @db.VarChar(30)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(0)

  students                    Student[]
  executives                  Executive[]
  professors                  Professor[]
  employees                   Employee[]
  files                       File[]
  authActivatedRefreshTokens  AuthActivatedRefreshTokens[]
  meetingAttendanceTimes      MeetingAttendanceTimeT[]
  meetingVoteResults          MeetingVoteResult[]
  userPrivacyPolicyAgreements UserPrivacyPolicyAgreement[]

  @@map("user")
}

model Student {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  number    Int       @unique
  name      String    @db.VarChar(255)
  email     String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  user                            User?                            @relation(fields: [userId], references: [id])
  studentTs                       StudentT[]
  activityParticipants            ActivityParticipant[]
  activityCertificates            ActivityCertificate[]
  clubStudentTs                   ClubStudentT[]
  clubDelegateDs                  ClubDelegateD[]
  commonSpaceUsageOrders          CommonSpaceUsageOrderD[]
  divisionPresidentDs             DivisionPresidentD[]
  registrations                   Registration[]
  registrationApplicationStudents RegistrationApplicationStudent[]
  rentalOrders                    RentalOrder[]
  promotionalPrintingOrders       PromotionalPrintingOrder[]
  fundingTransportationPassengers FundingTransportationPassenger[]
  clubDelegateChangeRequestsPrev  ClubDelegateChangeRequest[]      @relation("PrevStudent")
  clubDelegateChangeRequestsNew   ClubDelegateChangeRequest[]      @relation("NewStudent")
  executive                       Executive?

  @@map("student")
}

model StudentT {
  id                Int       @id @default(autoincrement())
  studentId         Int       @map("student_id")
  studentEnum       Int       @map("student_enum")
  studentStatusEnum Int       @map("student_status_enum")
  department        Int?
  semesterId        Int       @map("semester_id")
  startTerm         DateTime  @map("start_term") @db.DateTime(0)
  endTerm           DateTime? @map("end_term") @db.DateTime(0)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamp(0)

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, semesterId], map: "student_t_student_id_semester_id_unique_key")
  @@map("student_t")
}

model Executive {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  studentId Int       @unique(map: "student_id_unique") @map("student_id")
  name      String    @db.VarChar(255)
  email     String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  user                          User?                          @relation(fields: [userId], references: [id])
  student                       Student                        @relation(fields: [studentId], references: [id])
  executiveTs                   ExecutiveT[]
  activityChargedActivities     Activity[]                     @relation("ChargedExecutive")
  activityCommentedActivities   Activity[]                     @relation("CommentedExecutive")
  activityFeedbacks             ActivityFeedback[]
  activityClubChargedExecutives ActivityClubChargedExecutive[]
  fundingChargedFundings        Funding[]
  fundingFeedbacks              FundingFeedback[]
  registrationExecutiveComments RegistrationExecutiveComment[]

  @@map("executive")
}

model ExecutiveStatusEnum {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(30)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  executiveTs ExecutiveT[]

  @@map("executive_status_enum")
}

model ExecutiveBureauEnum {
  id   Int     @id @default(autoincrement())
  name String? @db.VarChar(31)

  executiveTs ExecutiveT[]

  @@map("executive_bureau_enum")
}

model ExecutiveT {
  id                  Int       @id @default(autoincrement())
  executiveId         Int       @map("executive_id")
  executiveStatusEnum Int       @map("executive_status_enum")
  executiveBureauEnum Int       @map("executive_bureau_enum")
  startTerm           DateTime  @map("start_term") @db.DateTime(0)
  endTerm             DateTime? @map("end_term") @db.DateTime(0)
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamp(0)

  executive          Executive           @relation(fields: [executiveId], references: [id])
  executiveStatusRel ExecutiveStatusEnum @relation(fields: [executiveStatusEnum], references: [id])
  executiveBureauRel ExecutiveBureauEnum @relation(fields: [executiveBureauEnum], references: [id])

  @@map("executive_t")
}

model Professor {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  name      String    @db.VarChar(255)
  email     String?   @unique @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  user          User?          @relation(fields: [userId], references: [id])
  professorTs   ProfessorT[]
  clubTs        ClubT[]
  registrations Registration[]

  @@map("professor")
}

model ProfessorT {
  id            Int       @id @default(autoincrement())
  professorId   Int       @unique @map("professor_id")
  professorEnum Int?      @map("professor_enum")
  department    Int?
  startTerm     DateTime  @map("start_term") @db.DateTime(0)
  endTerm       DateTime? @map("end_term") @db.DateTime(0)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(0)

  professor Professor @relation(fields: [professorId], references: [id])

  @@map("professor_t")
}

model Employee {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  name      String    @db.VarChar(255)
  email     String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  user       User?       @relation(fields: [userId], references: [id])
  employeeTs EmployeeT[]

  @@map("employee")
}

model EmployeeT {
  id         Int       @id @default(autoincrement())
  employeeId Int       @unique @map("employee_id")
  startTerm  DateTime  @map("start_term") @db.DateTime(0)
  endTerm    DateTime? @map("end_term") @db.DateTime(0)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_t")
}

model StudentStatusEnum {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(30)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("student_status_enum")
}

model StudentEnum {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(30)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("student_enum")
}

model ProfessorEnum {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(30)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("professor_enum")
}

model Department {
  id           Int       @id @default(autoincrement())
  departmentId Int?      @unique @map("department_id")
  name         String    @db.VarChar(255)
  nameEn       String?   @map("name_en") @db.VarChar(255)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("department")
}

model UserPrivacyPolicyAgreement {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id])

  @@map("user_privacy_policy_agreement")
}

model AuthActivatedRefreshTokens {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  expiresAt    DateTime @map("expires_at") @db.DateTime(0)
  refreshToken String   @map("refresh_token") @db.Text

  user User @relation(fields: [userId], references: [id])

  @@index([expiresAt], map: "expires_at_idx")
  @@map("auth_activated_refresh_tokens")
}

// ============================================================================
// Club
// ============================================================================

model Club {
  id           Int       @id @default(autoincrement())
  nameKr       String?   @unique @map("name_kr") @db.VarChar(30)
  nameEn       String?   @unique @map("name_en") @db.VarChar(100)
  description  String?   @db.Text
  foundingYear Int       @map("founding_year")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  clubTs                          ClubT[]
  clubDivisionHistories           ClubDivisionHistory[]
  clubStudentTs                   ClubStudentT[]
  clubRoomTs                      ClubRoomT[]
  clubDelegateDs                  ClubDelegateD[]
  clubDelegateChangeRequests      ClubDelegateChangeRequest[]
  activities                      Activity[]
  activityCertificates            ActivityCertificate[]
  activityClubChargedExecutives   ActivityClubChargedExecutive[]
  professorSignStatuses           ProfessorSignStatus[]
  commonSpaceUsageOrders          CommonSpaceUsageOrderD[]
  divisionPermanentClubDs         DivisionPermanentClubD[]
  fundings                        Funding[]
  registrations                   Registration[]
  registrationApplicationStudents RegistrationApplicationStudent[]
  rentalOrders                    RentalOrder[]
  promotionalPrintingOrders       PromotionalPrintingOrder[]
  meetingAttendanceDays           MeetingAttendanceDay[]

  @@map("club")
}

model ClubStatusEnum {
  id         Int       @id @default(autoincrement())
  statusName String?   @map("status_name") @db.VarChar(30)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  clubTs ClubT[]

  @@map("club_status_enum")
}

model ClubT {
  id               Int       @id @default(autoincrement())
  clubId           Int       @map("club_id")
  clubStatusEnumId Int       @map("club_status_enum_id")
  characteristicKr String?   @map("characteristic_kr") @db.VarChar(255)
  characteristicEn String?   @map("characteristic_en") @db.VarChar(255)
  professorId      Int?      @map("professor_id")
  semesterId       Int       @map("semester_id")
  startTerm        DateTime  @map("start_term") @db.DateTime(0)
  endTerm          DateTime? @map("end_term") @db.DateTime(0)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  club           Club           @relation(fields: [clubId], references: [id])
  clubStatusEnum ClubStatusEnum @relation(fields: [clubStatusEnumId], references: [id])
  professor      Professor?     @relation(fields: [professorId], references: [id])
  semester       SemesterD      @relation(fields: [semesterId], references: [id])

  @@map("club_t")
}

// NOTE: ClubSemester was an alias of ClubT in Drizzle (same DB table club_t).
// In Prisma, use the ClubT model for both old ClubT and ClubSemester queries.

model ClubDivisionHistory {
  id         Int       @id @default(autoincrement())
  clubId     Int       @map("club_id")
  divisionId Int       @map("division_id")
  startTerm  DateTime  @map("start_term") @db.DateTime(0)
  endTerm    DateTime? @map("end_term") @db.DateTime(0)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  club     Club     @relation(fields: [clubId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])

  @@map("club_division_t")
}

model ClubStudentT {
  id         Int       @id @default(autoincrement())
  studentId  Int       @map("student_id")
  clubId     Int       @map("club_id")
  semesterId Int       @map("semester_id")
  startTerm  DateTime  @map("start_term") @db.DateTime(0)
  endTerm    DateTime? @map("end_term") @db.DateTime(0)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  student  Student   @relation(fields: [studentId], references: [id])
  club     Club      @relation(fields: [clubId], references: [id])
  semester SemesterD @relation(fields: [semesterId], references: [id])

  @@map("club_student_t")
}

model ClubBuildingEnum {
  id           Int       @id @default(autoincrement())
  buildingName String?   @map("building_name") @db.VarChar(30)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  clubRoomTs ClubRoomT[]

  @@map("club_building_enum")
}

model ClubRoomT {
  id               Int       @id @default(autoincrement())
  clubId           Int       @map("club_id")
  clubBuildingEnum Int       @map("club_building_enum")
  roomLocation     String?   @map("room_location") @db.VarChar(20)
  roomPassword     String?   @map("room_password") @db.VarChar(20)
  semesterId       Int       @map("semester_id")
  startTerm        DateTime  @map("start_term") @db.DateTime(0)
  endTerm          DateTime? @map("end_term") @db.DateTime(0)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  club            Club             @relation(fields: [clubId], references: [id])
  clubBuildingRel ClubBuildingEnum @relation(fields: [clubBuildingEnum], references: [id])
  semester        SemesterD        @relation(fields: [semesterId], references: [id])

  @@map("club_room_t")
}

model ClubDelegateEnum {
  id        Int       @id @default(autoincrement())
  name      String?   @map("enum_name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("club_delegate_enum")
}

model ClubDelegateD {
  id               Int       @id @default(autoincrement())
  clubId           Int       @map("club_id")
  studentId        Int       @map("student_id")
  clubDelegateEnum Int       @map("club_delegate_enum_id")
  startTerm        DateTime  @map("start_term") @db.DateTime(0)
  endTerm          DateTime? @map("end_term") @db.DateTime(0)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  club    Club    @relation(fields: [clubId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([clubDelegateEnum], map: "club_delegate_d_club_delegate_enum_id_fk")
  @@map("club_delegate_d")
}

model ClubDelegateChangeRequestStatusEnum {
  id        Int       @id @default(autoincrement()) @map("enum_id")
  enumName  String    @map("enum_name") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  clubDelegateChangeRequests ClubDelegateChangeRequest[]

  @@map("club_delegate_change_request_status_enum")
}

model ClubDelegateChangeRequest {
  id                                    Int       @id @default(autoincrement())
  clubId                                Int       @map("club_id")
  prevStudentId                         Int       @map("prev_student_id")
  studentId                             Int       @map("student_id")
  clubDelegateChangeRequestStatusEnumId Int       @map("club_delegate_change_request_status_enum_id")
  createdAt                             DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt                             DateTime? @map("deleted_at") @db.Timestamp(0)

  club        Club                                @relation(fields: [clubId], references: [id])
  prevStudent Student                             @relation("PrevStudent", fields: [prevStudentId], references: [id])
  student     Student                             @relation("NewStudent", fields: [studentId], references: [id])
  statusEnum  ClubDelegateChangeRequestStatusEnum @relation(fields: [clubDelegateChangeRequestStatusEnumId], references: [id], map: "club_delegate_change_request_fk")

  @@map("club_delegate_change_request")
}

// ============================================================================
// Division
// ============================================================================

model District {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(10)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  divisions Division[]

  @@map("district")
}

model Division {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(10)
  startTerm  DateTime  @default(dbgenerated("'2017-03-01 00:00:00'")) @map("start_term") @db.DateTime(0)
  endTerm    DateTime? @map("end_term") @db.DateTime(0)
  districtId Int       @map("district_id")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  district              District               @relation(fields: [districtId], references: [id])
  clubDivisionHistories ClubDivisionHistory[]
  divisionPresidentDs   DivisionPresidentD[]
  registrations         Registration[]
  meetingAttendanceDays MeetingAttendanceDay[]

  @@map("division")
}

model DivisionPresidentD {
  id               Int       @id @default(autoincrement())
  divisionId       Int       @map("division_id")
  studentId        Int       @map("student_id")
  startTerm        DateTime  @map("start_term") @db.DateTime(0)
  endTerm          DateTime? @map("end_term") @db.DateTime(0)
  originatedClubId Int       @map("originated_club_id")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  division Division @relation(fields: [divisionId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])

  @@map("division_president_d")
}

model DivisionPermanentClubD {
  id        Int       @id @default(autoincrement())
  clubId    Int       @map("club_id")
  startTerm DateTime  @map("start_term") @db.DateTime(0)
  endTerm   DateTime? @map("end_term") @db.DateTime(0)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, startTerm], map: "division_permanent_club_d_club_id_start_term_unique")
  @@map("division_permanent_club_d")
}

// ============================================================================
// Semester
// ============================================================================

model SemesterD {
  id        Int       @id @default(autoincrement())
  year      Int
  name      String    @db.VarChar(10)
  startTerm DateTime  @map("start_term") @db.DateTime(0)
  endTerm   DateTime  @map("end_term") @db.DateTime(0)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  clubTs                          ClubT[]
  clubStudentTs                   ClubStudentT[]
  clubRoomTs                      ClubRoomT[]
  professorSignStatuses           ProfessorSignStatus[]
  registrations                   Registration[]
  registrationApplicationStudents RegistrationApplicationStudent[]
  registrationDeadlineDs          RegistrationDeadlineD[]

  @@map("semester_d")
}

model ActivityD {
  id                       Int       @id @default(autoincrement())
  semesterId               Int       @map("semester_id")
  year                     Int
  name                     String    @db.VarChar(10)
  startTerm                DateTime  @map("start_term") @db.DateTime(0)
  endTerm                  DateTime  @map("end_term") @db.DateTime(0)
  activityDurationTypeEnum Int       @map("activity_duration_type_enum")
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt                DateTime? @map("deleted_at") @db.Timestamp(0)

  activities                    Activity[]
  activityClubChargedExecutives ActivityClubChargedExecutive[]
  fundings                      Funding[]

  @@map("activity_d")
}

model ActivityDeadlineD {
  id           Int       @id @default(autoincrement())
  semesterId   Int       @map("semester_id")
  deadlineEnum Int       @map("deadline_enum_id")
  startTerm    DateTime  @map("start_term") @db.DateTime(0)
  endTerm      DateTime  @map("end_term") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("activity_deadline_d")
}

model FundingDeadlineD {
  id           Int       @id @default(autoincrement())
  semesterId   Int       @map("semester_id")
  deadlineEnum Int       @map("deadline_enum")
  startTerm    DateTime  @map("start_term") @db.DateTime(0)
  endTerm      DateTime  @map("end_term") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("funding_deadline_d")
}

model RegistrationDeadlineD {
  id           Int       @id @default(autoincrement())
  semesterId   Int?      @map("semester_d_id")
  deadlineEnum Int       @map("registration_deadline_enum_id")
  startTerm    DateTime  @map("start_term") @db.DateTime(0)
  endTerm      DateTime  @map("end_term") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(0)

  semester SemesterD? @relation(fields: [semesterId], references: [id])

  @@map("registration_deadline_d")
}

// ============================================================================
// Activity
// ============================================================================

model ActivityTypeEnum {
  id        Int       @id @default(autoincrement())
  typeName  String    @map("type_name") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  @@map("activity_type_enum")
}

model ActivityStatusEnum {
  id         Int       @id @default(autoincrement())
  statusName String    @map("status_name") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  activities        Activity[]
  activityFeedbacks ActivityFeedback[]

  @@map("activity_status_enum")
}

model Activity {
  id                   Int       @id @default(autoincrement())
  clubId               Int       @map("club_id")
  originalName         String    @map("original_name") @db.VarChar(255)
  name                 String    @db.VarChar(255)
  activityTypeEnumId   Int       @map("activity_type_enum_id")
  location             String    @db.VarChar(255)
  purpose              String    @db.Text
  detail               String    @db.Text
  evidence             String    @db.Text
  activityDId          Int       @map("activity_d_id")
  activityStatusEnumId Int       @map("activity_status_enum_id")
  chargedExecutiveId   Int?      @map("charged_executive_id")
  professorApprovedAt  DateTime? @map("professor_approved_at") @db.Timestamp(0)
  commentedAt          DateTime? @map("commented_at") @db.Timestamp(0)
  /// @deprecated Use the latest non-deleted `activity_feedback.executive_id` for the final reviewer.
  commentedExecutiveId Int?      @map("commented_executive_id")
  editedAt             DateTime  @default(now()) @map("edited_at") @db.Timestamp(0)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
