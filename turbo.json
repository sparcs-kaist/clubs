{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "//#dev:setup": {
      "dependsOn": [
        "@clubs/domain#build",
        "@clubs/interface#build",
        "api#prisma:generate"
      ],
      "cache": false
    },
    "dev": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"],
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "api#dev": {
      "dependsOn": [
        "@clubs/interface#build",
        "@clubs/domain#build",
        "prisma:generate"
      ],
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "api#build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "prisma:generate": {
      "cache": false
    },
    "db-up": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"]
    },
    "db-down": {},
    "db-generate": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"]
    },
    "web#dev-mock": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"],
      "persistent": true,
      "interruptible": true
    },
    "web#storybook": {
      "persistent": true
    },
    "lint": {},
    "test": {}
  }
}
