{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "dev": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"],
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "clean": {
      "cache": false
    },
    "db-up": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"]
    },
    "db-down": {},
    "db-generate": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"]
    },
    "web#dev-mock": {
      "dependsOn": ["@clubs/interface#build", "@clubs/domain#build"],
      "persistent": true,
      "interruptible": true
    },
    "web#storybook": {
      "persistent": true
    },
    "lint": {}
  }
}
